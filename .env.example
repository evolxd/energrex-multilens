# ── API Keys ──────────────────────────────────────────────────────────
# Financial Modeling Prep  https://financialmodelingprep.com/developer
# Free tier: 250 req/day; paid tiers unlock more endpoints
FMP_API_KEY=your_fmp_key_here

# Finnhub  https://finnhub.io/
# Free tier: 60 req/min
FINNHUB_API_KEY=your_finnhub_key_here

# SEC EDGAR — no key required (public API, rate-limit: 10 req/s)
# yfinance  — no key required

# ── Optional tuning ────────────────────────────────────────────────────
# Hours before cached API responses are considered stale
CACHE_TTL_HOURS=24

# Max parallel workers for network fetching
MAX_WORKERS=8
